<Window x:Class="AMLabSlicer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svg="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
        xmlns:viewmodel="clr-namespace:AMLabSlicer.ViewModel"
        xmlns:views="clr-namespace:AMLabSlicer.Views"
        Title="AMLab Slicer" Height="720" Width="1280" Background="{DynamicResource WindowBackgroundBrush}" TextElement.Foreground="{DynamicResource PrimaryTextBrush}" MinHeight="600" MinWidth="800"
        WindowStyle="None" AllowsTransparency="False">


    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" ResizeBorderThickness="5" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodel:PrepareWorkspaceViewModel}">
            <views:PrepareWorkspaceView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{DynamicResource TitleBarBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <svg:SvgViewbox Source="/Assets/Images/AMLab_logo_rgb.svg" Width="25" Height="25" Margin="10 5 0 0"/>
            <Menu Grid.Column="1" Background="Transparent" FontSize="12" VerticalAlignment="Center" WindowChrome.IsHitTestVisibleInChrome="True" Margin="0 5 0 0">

                <MenuItem Padding="0">
                    <MenuItem.Header>
                        <TextBlock Text="文件" Width="50" TextAlignment="Center"/>
                    </MenuItem.Header>

                    <MenuItem Header="载入模型..." Command="{Binding LoadModelCommand}" Width="150" Padding="10,5"/>

                </MenuItem>

                <MenuItem Padding="0">
                    <MenuItem.Header>
                        <TextBlock Text="设置" Width="50" TextAlignment="Center"/>
                    </MenuItem.Header>
                    <MenuItem Header="首选项..." Command="{Binding OpenPreferencesCommand}" Width="150" Padding="10,5"/>
                </MenuItem>
            </Menu>

            <StackPanel Grid.Column="3" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Content="—" Width="45" Style="{StaticResource WindowButtonStyle}" Click="BtnMinimize_Click"/>
                <Button Content="☐" Width="45" Style="{StaticResource WindowButtonStyle}" Click="BtnMaximize_Click"/>
                <Button Content="✕" Width="45" Style="{StaticResource CloseButtonStyle}" Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Background="{DynamicResource ToolbarBackgroundBrush}">
            <Button Content="准 备" Width="120" Background="{DynamicResource WindowBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderThickness="0" FontWeight="Bold" FontSize="14"/>
            <Button Content="预 览" Width="120" Background="Transparent" Foreground="{DynamicResource SecondaryTextBrush}" BorderThickness="0" FontSize="14"/>
            <Button Content="设 备" Width="120" Background="Transparent" Foreground="{DynamicResource SecondaryTextBrush}" BorderThickness="0" FontSize="14"/>
        </StackPanel>

        <ContentControl Grid.Row="2" Content="{Binding CurrentWorkspace}" />
    </Grid>
</Window>