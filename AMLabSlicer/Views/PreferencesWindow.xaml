<Window x:Class="AMLabSlicer.Views.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="首选项" Height="450" Width="600"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="渲染与辅助功能首选项" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,20"/>
        
        <StackPanel Grid.Row="1" Margin="10,0">
            <CheckBox Content="开启后渲染消除锯齿 (FXAA)" IsChecked="{Binding EnableFXAA}" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,10"/>
            <TextBlock Text="改善模型边缘的锯齿感，适合大多数情况平滑画面。" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="25,0,0,10"/>
            
            <CheckBox Content="开启屏幕空间环境光遮蔽 (SSAO)" IsChecked="{Binding EnableSSAO}" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,10"/>
            <TextBlock Text="增强模型凹凸处的暗角阴影表现，可能增加一定性能消耗。" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="25,0,0,10"/>
            
            <Separator Margin="0,20" Background="{DynamicResource GridSplitterBrush}"/>
            
            <TextBlock Text="视图辅助工具" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,15"/>
            
            <CheckBox Content="显示三维坐标轴" IsChecked="{Binding ShowCoordinateSystem}" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,10"/>
            <CheckBox Content="显示视角导航立方体" IsChecked="{Binding ShowViewCube}" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,10"/>
            
            <Separator Margin="0,20" Background="{DynamicResource GridSplitterBrush}"/>
            
            <TextBlock Text="相机模式" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,15"/>
            
            <CheckBox Content="使用正交视角（关闭则为透视）" IsChecked="{Binding UseOrthographic}" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,10"/>
            <TextBlock Text="正交视角保持平行投影，适合精确对齐；透视视角更直观自然。" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="25,0,0,10"/>
        </StackPanel>
    </Grid>
</Window>