<UserControl x:Class="AMLabSlicer.Views.ModelPreviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hx="http://helix-toolkit.org/wpf/SharpDX" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             MinWidth="300" MinHeight="400"
             mc:Ignorable="d">

    <Grid Background="{DynamicResource ViewportBackgroundBrush}">

        <hx:Viewport3DX x:Name="MainViewport" 
                        BackgroundColor="#393939" 
                        ShowCoordinateSystem="{Binding AppPrefs.ShowCoordinateSystem}"
                        CoordinateSystemLabelForeground="{DynamicResource PrimaryTextColor}"
                        UseDefaultGestures="False"
                        IsInertiaEnabled="False"
                        IsPanEnabled="False"
                        IsRotationEnabled="False"
                        IsZoomEnabled="False"
                        IsMoveEnabled="False"
                        FXAALevel="{Binding AppPrefs.FXAALevel}"
                        PreviewMouseDown="MainViewport_PreviewMouseDown"
                        PreviewMouseUp="MainViewport_PreviewMouseUp"
                        PreviewMouseMove="MainViewport_PreviewMouseMove"
                        PreviewMouseWheel="MainViewport_PreviewMouseWheel">

            <!-- 相机由 Code-Behind 创建并赋值，此处不声明 -->

            <hx:AmbientLight3D Color="#333333" />

            <hx:DirectionalLight3D Direction="{Binding Camera.LookDirection, ElementName=MainViewport}" 
                                   Color="#CCCCCC" />
            <!-- 较细的底纹网格 -->
            <hx:LineGeometryModel3D Geometry="{Binding MinorGridGeometry}"
                                    Color="#333333" 
                                    Thickness="0.5" />

            <!-- 加粗的 10mm 间隔网格标记 -->
            <hx:LineGeometryModel3D Geometry="{Binding MajorGridGeometry}"
                                    Color="#666666" 
                                    Thickness="1" />
            <hx:Element3DPresenter Content="{Binding LoadedModel}" />
        </hx:Viewport3DX>

        <Button Command="{Binding TogglePanelCommand}" 
                Width="25" Height="25" HorizontalAlignment="Left" VerticalAlignment="Top" 
                Margin="0" Background="{DynamicResource MenuItemBackgroundBrush}" BorderThickness="0" Cursor="Hand">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Content" Value="&lt;"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsParameterPanelOpen}" Value="False">
                            <Setter Property="Content" Value="&gt;"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <Border HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,15,0,0" 
                Background="{DynamicResource ToolbarBackgroundBrush}" CornerRadius="5" Padding="15,5">
            <TextBlock Text="视角控制条 (移动 / 旋转 / 缩放)" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
        </Border>

    </Grid>
</UserControl>