<UserControl x:Class="AMLabSlicer.Views.ModelPreviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hx="http://helix-toolkit.org/wpf/SharpDX" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             MinWidth="300" MinHeight="400"
             mc:Ignorable="d">

    <Grid Background="{DynamicResource ViewportBackgroundBrush}">

        <hx:Viewport3DX x:Name="MainViewport" 
                        BackgroundColor="#2B2B2B" 
                        ShowCoordinateSystem="True"
                        CoordinateSystemLabelForeground="White"
                        UseDefaultGestures="True">

            <hx:Viewport3DX.Camera>
                <hx:PerspectiveCamera Position="200,100,200" 
                                      LookDirection="-200,-100,-200" 
                                      UpDirection="0,0,1" />
            </hx:Viewport3DX.Camera>

            <hx:AmbientLight3D Color="#333333" />

            <hx:DirectionalLight3D Direction="{Binding Camera.LookDirection, ElementName=MainViewport}" 
                                   Color="#CCCCCC" />
            <hx:LineGeometryModel3D Geometry="{Binding MinorGridGeometry}"
                                    Color="#333333" 
                                    Thickness="0.5" />

            <hx:LineGeometryModel3D Geometry="{Binding MajorGridGeometry}"
                                    Color="#666666" 
                                    Thickness="1" />
            <hx:Element3DPresenter Content="{Binding LoadedModel}" />

        </hx:Viewport3DX>

        <Button Command="{Binding TogglePanelCommand}" 
                Width="25" Height="25" HorizontalAlignment="Left" VerticalAlignment="Top" 
                Margin="0" Background="White" BorderThickness="0" Cursor="Hand">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Content" Value="&lt;"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsParameterPanelOpen}" Value="False">
                            <Setter Property="Content" Value="&gt;"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <Border HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,15,0,0" 
                Background="#444444" CornerRadius="5" Padding="15,5">
            <TextBlock Text="视角控制条 (移动 / 旋转 / 缩放)" Foreground="White" VerticalAlignment="Center"/>
        </Border>

    </Grid>
</UserControl>